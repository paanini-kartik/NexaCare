rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user workspace (profile, health, household, enterprises, onboarding)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Email → uid lookup for cross-user updates (family roles, etc.)
    match /usersByEmail/{email} {
      allow read, write: if request.auth != null;
    }
    // Shared join keys + families + employer keys (demo — tighten for production)
    match /appState/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
