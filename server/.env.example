# Anthropic — server-side only, never expose to browser
ANTHROPIC_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:8000/api/calendar/callback

# Firebase Admin — provide ONE of these
# Option A (recommended for production): paste the full JSON string
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B (local dev): path to the key file
FIREBASE_SERVICE_ACCOUNT_PATH=server/serviceAccountKey.json

# Deployment URLs
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev
DEMO_CLINIC_EMAIL=
